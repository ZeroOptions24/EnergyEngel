<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EnergyEngel – Telefonleitfaden</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    :root {
      --script-bg: #edf7f0;
      --script-bg-strong: #dff0e4;
      --script-border: #9fc8aa;
      --script-text: #14311d;
      --script-shadow: 0 10px 24px rgba(22, 84, 45, 0.10);
      --bg: #f5f7f6;
      --surface: #ffffff;
      --surface-soft: #f1f5f2;
      --line: #dbe5dd;
      --text: #18241d;
      --text-soft: #5f6d63;
      --brand: #1f6b3a;
      --brand-strong: #16542d;
      --brand-soft: #e8f3ec;
      --warn: #a53e2f;
      --warn-soft: #fdf0ed;
      --amber: #8a5a10;
      --amber-soft: #fcf4e8;
      --shadow: 0 10px 28px rgba(19, 31, 24, 0.06);
      --radius: 18px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 18px;
      line-height: 1.65;
    }
    button, input, textarea { font: inherit; }

    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--line);
      padding: 28px 24px 22px;
      position: sticky;
      top: 0;
      z-index: 30;
      transition: transform .2s ease, opacity .2s ease, max-height .2s ease, padding .2s ease;
    }
    body.guide-mode .header {
      transform: translateY(-100%);
      opacity: 0;
      max-height: 0;
      padding-top: 0;
      padding-bottom: 0;
      overflow: hidden;
      border-bottom: 0;
      pointer-events: none;
    }
    .header-wrap { max-width: 1100px; margin: 0 auto; }
    .eyebrow {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--brand);
      font-weight: 800;
      margin-bottom: 8px;
    }
    .title {
      font-size: 34px;
      line-height: 1.05;
      letter-spacing: -.03em;
      font-weight: 800;
    }
    .subtitle {
      margin-top: 6px;
      font-size: 17px;
      color: var(--text-soft);
      font-weight: 500;
    }

    .progress-shell {
      position: sticky;
      top: 8px;
      z-index: 25;
      max-width: 1100px;
      margin: 12px auto 0;
      padding: 0 16px;
      display: none;
    }
    body.guide-mode .progress-shell { display: block; }
    .progress-nav {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 8px 10px;
      display: grid;
      grid-template-columns: repeat(9, minmax(0, 1fr));
      align-items: stretch;
      gap: 6px;
      overflow: visible;
    }
    .progress-nav::-webkit-scrollbar { height: 0; }
    .progress-step {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 7px 9px;
      border: 1px solid #edf2ee;
      border-radius: 999px;
      background: #f8faf9;
      min-width: 0;
      cursor: pointer;
      transition: .18s ease;
      position: relative;
      transform-origin: center;
    }
    .progress-step:hover {
      background: var(--brand-soft);
      border-color: #cfe0d3;
    }
    .progress-dot {
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #eef2ef;
      color: var(--text-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 800;
      flex-shrink: 0;
      transition: .18s ease;
    }
    .progress-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-soft);
      line-height: 1.15;
      text-align: center;
      white-space: normal;
      transition: .18s ease;
    }
    .progress-step.active {
      background: #eef7f1;
      border-color: #b8d3c0;
      box-shadow: 0 10px 22px rgba(22, 84, 45, 0.10);
      transform: scale(1.08);
      z-index: 2;
    }
    .progress-step.active .progress-dot {
      width: 30px;
      height: 30px;
      background: var(--brand);
      color: #fff;
      border-color: var(--brand);
      font-size: 12px;
    }
    .progress-step.active .progress-label {
      color: var(--text);
      font-size: 12px;
      font-weight: 800;
    }
    .progress-step.done {
      background: #f4faf6;
      border-color: #d7e6db;
    }
    .progress-step.done .progress-dot {
      background: var(--brand-soft);
      color: var(--brand-strong);
      border-color: #cfe0d3;
    }
    .progress-step.done .progress-label { color: var(--brand-strong); }
    .progress-step.is-hidden {
      display: none;
    }

    .app {
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px 16px 72px;
    }
    .prep-screen, .guide-screen { display: none; }
    body.prep-mode .prep-screen { display: block; }
    body.guide-mode .guide-screen { display: block; }

    .progress-back {
      margin-left: 0;
      white-space: normal;
      min-width: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 6px 8px;
      min-height: 0;
      border-radius: 999px;
      background: #f8faf9;
      border: 1px solid #edf2ee;
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 700;
      box-shadow: none;
      cursor: pointer;
    }
    .progress-back:hover {
      background: var(--brand-soft);
      border-color: #cfe0d3;
      color: var(--brand-strong);
      transform: none;
    }
    .progress-back-dot {
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #eef2ef;
      color: var(--text-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 800;
      flex-shrink: 0;
    }
    .progress-back-label {
      font-size: 11px;
      font-weight: 700;
      color: inherit;
      line-height: 1.15;
      text-align: center;
    }

    .section {
      display: none;
      padding: 22px;
      border-radius: 24px;
      margin-bottom: 20px;
      border: 1px solid transparent;
    }
    .section.visible { display: block; }
    .prep-screen .section {
      background: #eef4f0;
      border-color: #dce7df;
    }
    #step-1 { background: #eef4fb; border-color: #d9e4f2; }
    #step-2 { background: #f4fbf6; border-color: #d9e7dd; }
    #step-3 { background: #eef7f1; border-color: #d9e7dd; }
    #step-4 { background: #eef7f1; border-color: #d9e7dd; }
    #step-5 { background: #fff1ed; border-color: #f0d5cd; }
    #step-6 { background: #f3f3fb; border-color: #ddddf0; }

    .section-head {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 18px;
    }
    .section-icon {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      background: var(--brand);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 800;
      flex-shrink: 0;
    }
    .section-icon.warn { background: var(--warn); }
    .section-title {
      font-size: 36px;
      line-height: 1.05;
      letter-spacing: -.03em;
      font-weight: 800;
    }
    .section-sub {
      margin-top: 8px;
      color: var(--text-soft);
      font-size: 18px;
    }

    .goal {
      background: var(--brand-soft);
      border: 2px solid #cfe0d3;
      border-left: 8px solid var(--brand);
      border-radius: 16px;
      padding: 18px 20px;
      margin-bottom: 16px;
      color: var(--text);
      font-size: 18px;
      line-height: 1.6;
    }
    .goal.warn {
      background: var(--warn-soft);
      border-left-color: var(--warn);
      border-color: #efd5cd;
    }
    .goal-label {
      display: block;
      margin-bottom: 8px;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--brand-strong);
      font-weight: 800;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 20px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
    }
    .badge {
      display: block;
      padding: 0;
      border-radius: 0;
      background: transparent;
      border: 0;
      color: var(--text);
      font-size: 22px;
      letter-spacing: -.02em;
      text-transform: none;
      font-weight: 800;
      margin-bottom: 8px;
    }
    .card-title {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text);
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 12px;
    }
    .card-title::before {
      content: '';
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: var(--brand);
      flex-shrink: 0;
    }
    .card-help {
      color: var(--text);
      font-size: 17px;
      line-height: 1.55;
      margin-bottom: 16px;
      padding: 14px 16px;
      background: var(--brand-soft);
      border: 2px solid #cfe0d3;
      border-left: 8px solid var(--brand);
      border-radius: 14px;
    }

    .grid-1 { display: grid; gap: 12px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .full { grid-column: 1 / -1; }
    .field { display: flex; flex-direction: column; gap: 8px; }
    .label {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--text-soft);
      font-weight: 800;
    }
    .input,
    .textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #fff;
      color: var(--text);
      padding: 14px 16px;
      font-size: 16px;
      outline: none;
      transition: border-color .15s ease, box-shadow .15s ease;
    }
    .textarea { min-height: 120px; resize: vertical; }
    .input:focus,
    .textarea:focus {
      border-color: #9fc8aa;
      box-shadow: 0 0 0 4px rgba(31,107,58,.08);
    }

    .choice {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: #fff;
      padding: 18px;
      display: grid;
      grid-template-columns: 48px 1fr auto;
      gap: 14px;
      align-items: center;
      text-align: left;
      cursor: pointer;
      transition: .16s ease;
      box-shadow: 0 4px 14px rgba(24,36,29,.04);
    }
    .choice:hover {
      transform: translateY(-1px);
      border-color: #b9c8bd;
      box-shadow: 0 8px 18px rgba(24,36,29,.07);
    }
    .choice.active {
      border-color: var(--brand);
      background: var(--brand-soft);
      box-shadow: 0 0 0 3px rgba(31,107,58,.10);
    }
    .choice-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: var(--surface-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
    }
    .choice-title {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.25;
      color: var(--text);
    }
    .choice-text {
      font-size: 14px;
      line-height: 1.45;
      color: var(--text-soft);
      margin-top: 4px;
    }
    .choice-tag {
      display: none;
    }

    .spoken-block {
      background: var(--script-bg);
      border: 2px solid var(--script-border);
      border-radius: 22px;
      box-shadow: var(--script-shadow);
      padding: 26px;
      margin-top: 16px;
      display: none;
      position: relative;
    }
    .spoken-block::before {
      content: 'Sagen';
      position: absolute;
      top: -18px;
      right: 20px;
      background: var(--script-bg-strong);
      color: var(--script-text);
      border: 3px solid var(--script-border);
      border-radius: 999px;
      padding: 10px 18px;
      font-size: 16px;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      box-shadow: 0 10px 24px rgba(22, 84, 45, 0.16);
      z-index: 2;
    }
    .spoken-block.active { display: block; }
    .spoken-label {
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--script-text);
      font-weight: 800;
      margin-bottom: 18px;
    }
    .spoken-item {
      display: grid;
      grid-template-columns: 36px 1fr;
      gap: 16px;
      padding: 18px;
      margin-bottom: 14px;
      border: 1px solid rgba(159, 200, 170, 0.95);
      border-radius: 18px;
      background: rgba(255,255,255,0.45);
    }
    .spoken-item.hidden { display: none; }
    .spoken-item:last-child { margin-bottom: 0; }
    .spoken-num {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: var(--script-text);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 800;
      margin-top: 2px;
    }
    .spoken-text {
      font-size: 28px;
      line-height: 1.55;
      font-weight: 800;
      color: var(--script-text);
      letter-spacing: -0.01em;
    }
    .spoken-note { display: none; }

    .response-actions {
      display: flex;
      gap: 16px;
      justify-content: center;
      align-items: center;
      margin-top: 18px;
      flex-wrap: wrap;
    }
    .response-actions .btn-primary,
    .response-actions .btn-secondary {
      min-width: 220px;
      min-height: 64px;
      padding: 18px 28px;
      font-size: 18px;
      font-weight: 800;
    }
    .response-actions.hidden { display: none; }

    .quote-box {
      background: var(--script-bg);
      border: 2px solid var(--script-border);
      border-left: 10px solid var(--brand);
      border-radius: 18px;
      box-shadow: var(--script-shadow);
      padding: 24px 24px 22px;
      font-size: 30px;
      line-height: 1.5;
      font-weight: 800;
      color: var(--script-text);
      letter-spacing: -0.01em;
      position: relative;
    }
    .quote-box::before {
      content: 'Sagen';
      position: absolute;
      top: -18px;
      right: 20px;
      background: var(--script-bg-strong);
      color: var(--script-text);
      border: 3px solid var(--script-border);
      border-radius: 999px;
      padding: 10px 18px;
      font-size: 16px;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      box-shadow: 0 10px 24px rgba(22, 84, 45, 0.16);
      z-index: 2;
    }
    .quote-box.hidden { display: none; }
    .quote-box.warn-state {
      background: var(--warn-soft);
      border-color: #e3b6ad;
      border-left-color: var(--warn);
      color: #4a1f18;
      box-shadow: 0 10px 24px rgba(165, 62, 47, 0.12);
    }
    .quote-box.warn-state::before {
      background: #f6ddd8;
      border-color: #e3b6ad;
      color: #4a1f18;
    }
    .followup-quote { display: none; margin-top: 16px; }
    .followup-quote.visible { display: block; }
    .say-focus {
      box-shadow: 0 0 0 4px rgba(31,107,58,.14), var(--script-shadow) !important;
      transform: scale(1.01);
      transition: box-shadow .2s ease, transform .2s ease;
    }
    .say-change {
      animation: sayPulse .38s ease;
    }
    @keyframes sayPulse {
      0% { transform: scale(1); }
      45% { transform: scale(1.04); }
      100% { transform: scale(1); }
    }

    .say-stack {
      display: grid;
      gap: 14px;
      margin-bottom: 16px;
    }
    .compact-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      box-shadow: var(--shadow);
    }
    .motive-grid-compact {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .choice.compact {
      padding: 16px;
      grid-template-columns: 38px 1fr;
      gap: 10px;
      min-height: 0;
      border-radius: 16px;
    }
    .choice.compact .choice-icon {
      width: 38px;
      height: 38px;
      font-size: 20px;
      border-radius: 10px;
    }
    .choice.compact .choice-title {
      font-size: 15px;
      line-height: 1.25;
    }
    .choice.compact .choice-text {
      font-size: 12px;
      margin-top: 2px;
      line-height: 1.35;
    }
    .stage-lock {
      position: relative;
    }
    .stage-lock.is-locked {
      pointer-events: none;
      user-select: none;
    }
    .stage-lock.is-locked .stage-lock-body {
      filter: blur(9px);
      opacity: 0.14;
    }
    .stage-lock .lock-overlay {
      display: none;
    }
    .stage-lock.is-locked .lock-overlay {
      display: flex;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 16px;
      z-index: 3;
      font-size: 16px;
      font-weight: 800;
      color: var(--text);
      background: transparent;
      border-radius: 14px;
      text-shadow: 0 1px 2px rgba(255,255,255,0.85);
    }
    .section.is-locked {
      position: relative;
      overflow: hidden;
    }
    .section.is-locked > *:not(.lock-overlay) {
      filter: blur(8px);
      opacity: 0.22;
      pointer-events: none;
      user-select: none;
    }
    .section .lock-overlay {
      display: none;
    }
    .section.is-locked .lock-overlay {
      display: flex;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;
      padding: 24px;
      text-align: center;
      z-index: 4;
      font-size: 20px;
      font-weight: 800;
      color: var(--text);
      background: transparent;
      text-shadow: 0 1px 2px rgba(255,255,255,0.9);
    }

    .tech-sections {
      display: grid;
      gap: 8px;
      align-items: start;
    }
    .tech-select-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      align-items: start;
    }
    .tech-slider-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      align-items: start;
    }
    .tech-card {
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 14px;
      display: grid;
      grid-template-rows: auto auto;
      gap: 8px;
      background: #ffffff;
      box-shadow: 0 4px 12px rgba(24, 36, 29, 0.04);
      align-content: start;
      min-height: 100%;
      transition: box-shadow .18s ease, border-color .18s ease;
    }
    .tech-card-body {
      display: grid;
      gap: 8px;
    }
    .tech-summary {
      display: none;
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #ffffff;
      font-size: 12px;
      font-weight: 700;
      color: var(--brand-strong);
      line-height: 1.35;
    }
    .tech-card.is-idle {
      position: relative;
      background: #eef7f1;
      border-color: #cfe0d3;
      box-shadow: 0 8px 18px rgba(22, 84, 45, 0.10);
      opacity: 1;
      overflow: hidden;
    }
    .tech-card.is-idle .tech-card-body {
      filter: blur(8px);
      opacity: 0.12;
      pointer-events: none;
      user-select: none;
    }
    .tech-card.is-idle .tech-summary {
      display: none;
    }
    .tech-card.is-idle .tech-card-title {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 14px;
      z-index: 2;
      margin: 0;
      background: transparent;
      pointer-events: none;
    }
    .tech-card.is-idle .tech-card-num {
      display: none;
    }
    .tech-card.is-idle .tech-card-head {
      color: var(--brand-strong);
      font-size: 18px;
      line-height: 1.2;
      font-weight: 800;
      letter-spacing: -0.01em;
      max-width: 100%;
      text-wrap: balance;
    }
    .tech-card.tech-question-card {
      cursor: pointer;
    }
    .tech-card.tech-question-card:hover {
      border-color: #b9c8bd;
      box-shadow: 0 8px 18px rgba(24,36,29,.08);
    }
    .tech-card.tech-question-card.is-active {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(31,107,58,.10), 0 8px 18px rgba(24,36,29,.08);
    }
    .tech-card.tech-question-card.is-idle {
      transition: box-shadow .22s ease, background .22s ease, border-color .22s ease;
    }
    .tech-card.wide {
      grid-column: 1 / -1;
      grid-template-rows: auto auto;
    }
    .tech-card-title {
      display: grid;
      grid-template-columns: 24px 1fr;
      gap: 10px;
      align-items: center;
      margin-bottom: 2px;
    }
    .tech-card-num {
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: var(--brand);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 800;
      flex-shrink: 0;
      margin-top: 0;
    }
    .tech-card-head {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.18;
      color: var(--text);
      letter-spacing: -0.01em;
    }
    .tech-card-sub { display: none; }

    .tech-detail {
