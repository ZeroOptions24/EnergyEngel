        setText('econHeatUsageMin', '0 l');
        setText('econHeatUsageMax', '8.000 l');
        setText('econHeatUsageValue', `${formatNumberDE(Number(slider.value))} l / Jahr`);
      } else if (state.heatSource === 'gas') {
        slider.min = '0';
        slider.max = '45000';
        slider.step = '500';
        setText('econHeatUsageMin', '0 kWh');
        setText('econHeatUsageMax', '45.000 kWh');
        setText('econHeatUsageValue', `${formatNumberDE(Number(slider.value))} kWh / Jahr`);
      } else {
        slider.min = '0';
        slider.max = '45000';
        slider.step = '500';
        setText('econHeatUsageMin', '0');
        setText('econHeatUsageMax', '—');
        setText('econHeatUsageValue', 'Nicht relevant');
      }
    }

    function updateHeatUsageUI() {
      const slider = $('heatUsageSlider');
      const min = $('heatUsageMin');
      const max = $('heatUsageMax');
      const value = $('heatUsageValue');
      const note = $('heatUsageNote');
      const detail = $('heatUsageDetail');
      if (!slider || !min || !max || !value || !note || !detail) return;

      detail.classList.remove('is-disabled');
      slider.disabled = false;

      if (state.heatSource === 'oil') {
        slider.min = '0';
        slider.max = '8000';
        slider.step = '100';
        if (state.heatUsage > 8000) state.heatUsage = 2000;
        slider.value = String(state.heatUsage || 2000);
        min.textContent = '0 l';
        max.textContent = '8.000 l';
        note.textContent = 'Ölverbrauch pro Jahr.';
        value.textContent = `${formatNumberDE(Number(slider.value))} l / Jahr`;
      } else if (state.heatSource === 'gas') {
        if (!state.heatUsageManual) {
          state.heatUsage = getAutoGasUsage();
        }
        slider.min = '0';
        slider.max = '45000';
        slider.step = '500';
        slider.value = String(state.heatUsage || getAutoGasUsage());
        min.textContent = '0 kWh';
        max.textContent = '45.000 kWh';
        note.textContent = 'Automatisch aus Wohnfläche × Kennwert berechnet.';
        value.textContent = `${formatNumberDE(Number(slider.value))} kWh / Jahr`;
      } else {
        slider.min = '0';
        slider.max = '45000';
        slider.step = '500';
        slider.value = '0';
        slider.disabled = true;
        min.textContent = '0';
        max.textContent = '—';
        note.textContent = 'Für andere Heizsysteme ist hier kein Verbrauchs-Schieber nötig.';
        value.textContent = 'Nicht relevant';
        detail.classList.add('is-disabled');
