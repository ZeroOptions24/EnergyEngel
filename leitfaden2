        <div class="card">
          <div class="card-title">PDF / Gesprächsprotokoll</div>
          <div class="summary">
            <div class="summary-grid">
              <div class="summary-item"><div class="summary-key">Kunde</div><div class="summary-value" id="summary-name">—</div></div>
              <div class="summary-item"><div class="summary-key">Telefon</div><div class="summary-value" id="summary-telefon">—</div></div>
              <div class="summary-item"><div class="summary-key">E-Mail</div><div class="summary-value" id="summary-email">—</div></div>
              <div class="summary-item"><div class="summary-key">Ort / Adresse</div><div class="summary-value" id="summary-ort">—</div></div>
              <div class="summary-item"><div class="summary-key">Kontaktart</div><div class="summary-value" id="summary-pfad">—</div></div>
              <div class="summary-item"><div class="summary-key">Thema</div><div class="summary-value" id="summary-thema">—</div></div>
              <div class="summary-item"><div class="summary-key">Geplanter Termin</div><div class="summary-value" id="summary-termin">—</div></div>
              <div class="summary-item"><div class="summary-key">Berater</div><div class="summary-value" id="summary-berater">—</div></div>
              <div class="summary-item" style="grid-column:1 / -1;"><div class="summary-key">Notizen</div><div class="summary-value" id="summary-notizen">—</div></div>
            </div>
            <div class="actions">
              <button class="btn-primary" type="button" id="exportBtn">PDF / Druckansicht öffnen</button>
              <button class="btn-secondary" type="button" id="refreshBtn">Zusammenfassung aktualisieren</button>
            </div>
          </div>
        </div>
      </section>
    </section>
  </main>

  <div class="footer">EnergyEngel Telefonleitfaden · Interne Live-Version</div>

  <script>
    const state = {
      mode: 'prep',
      pfad: null,
      thema: null,
      currentStep: 0,
      tags: new Set(),
      motive: new Set(),
      termSteps: new Set(),
      lastMotive: null,
      entryDone: false,
      motiveConfirm: null,
      techDone: { heatSelect: false, pv: false, building: false, size: false, heat: false, power: false },
      econDone: { building: false, size: false, heat: false, power: false },
      buildingType: 'altbau',
      buildingSubtype: 'Nach 3. WSchVO',
      buildingKwhPerSqm: 100,
      buildingYear: 1995,
      houseSize: 140,
      heatSource: 'gas',
      heatUsage: 14000,
      heatUsageManual: false,
      powerUsage: 3500,
      pvAnlage: null,
      kundenDaten: { name: '', telefon: '', email: '', ort: '', termin: '', berater: '', notizen: '' }
    };

    const techIdleTimers = { building: null, size: null, heat: null, power: null, heatSelect: null, pv: null };
    const techIdleEnabled = { building: false, size: false, heat: false, power: false, heatSelect: false, pv: false };
    let isSnappingQuestion = false;
    let technicalQuestionLockUntil = 0;

    const guideText = {
      wp: {
        step1Goal: 'Du eröffnest das Gespräch klar auf das Thema Wärmepumpe und führst dann direkt in die Bedarfsermittlung.',
        openingQuestion: '„Kurz gefragt: Wie kommen Sie gerade zu dem Thema Wärmepumpe?“',
        step3Sub: 'Nur Wärmepumpen-Argumente zeigen, die zur Situation des Kunden passen.',
        interestIntro: '„Lassen Sie mich kurz sagen, was Kunden in einer ähnlichen Wärmepumpen-Situation bei uns am Ende gesagt haben.“',
        defaultObjection: 'wp'
      },
      pv: {
        step1Goal: 'Du eröffnest das Gespräch klar auf das Thema Photovoltaik und führst dann direkt in die Bedarfsermittlung.',
        openingQuestion: '„Kurz gefragt: Wie kommen Sie gerade zu dem Thema Photovoltaik?“',
        step3Sub: 'Nur Photovoltaik-Argumente zeigen, die zur Situation des Kunden passen.',
        interestIntro: '„Lassen Sie mich kurz sagen, was Kunden in einer ähnlichen Photovoltaik-Situation bei uns am Ende gesagt haben.“',
        defaultObjection: 'pv'
      },
      sg: {
        step1Goal: 'Du eröffnest das Gespräch klar auf Strom & Gas und führst dann direkt in die Bedarfsermittlung.',
        openingQuestion: '„Kurz gefragt: Wie kommen Sie gerade zu dem Thema Strom & Gas?“',
        step3Sub: 'Nur passende Kosten- und Nutzenargumente zeigen.',
        interestIntro: '„Lassen Sie mich kurz sagen, was Kunden in einer ähnlichen Strom-&-Gas-Situation bei uns am Ende gesagt haben.“',
        defaultObjection: 'allg'
      },
      empfehlung: {
        step1Goal: 'Du nutzt den Vertrauensvorschuss der Empfehlung und gehst danach sauber ins Thema.',
        openingQuestion: '„Kurz gefragt: Was war für Sie der Anlass, dass wir heute miteinander sprechen?“',
        step3Sub: 'Nur die Argumente zeigen, die zur Situation des empfohlenen Kontakts passen.',
        interestIntro: '„Lassen Sie mich kurz sagen, was Kunden in einer ähnlichen Situation bei uns am Ende gesagt haben.“',
        defaultObjection: 'allg'
      }
    };

    const $ = (id) => document.getElementById(id);
    const $$ = (sel) => Array.from(document.querySelectorAll(sel));
    const setText = (id, value) => {
      const el = $(id);
      if (el) el.textContent = value;
    };

    function valueOrDash(v) { return String(v || '').trim() || '—'; }
    function getPfadLabel() { return state.pfad === 'lead' ? 'Warmer Lead' : state.pfad === 'empfehlung' ? 'Empfehlung' : '—'; }
    function getThemaLabel() {
      if (state.thema === 'wp') return 'Wärmepumpe';
      if (state.thema === 'pv') return 'Photovoltaik';
      if (state.thema === 'sg') return 'Strom & Gas';
      if (state.pfad === 'empfehlung') return 'Empfehlungsfall / offen';
      return '—';
    }
    function currentGuide() {
      if (state.pfad === 'empfehlung') return guideText.empfehlung;
      return guideText[state.thema] || guideText.wp;
    }

    function setMode(mode) {
      state.mode = mode;
      document.body.classList.remove('prep-mode', 'guide-mode');
      document.body.classList.add(mode === 'guide' ? 'guide-mode' : 'prep-mode');
    }

    function updateProgress(step) {
      state.currentStep = step;
      $$('.progress-step').forEach((el) => {
        const n = Number(el.dataset.progress);
        el.classList.remove('active', 'done');
        if (n < step) el.classList.add('done');
        if (n === step) el.classList.add('active');
      });
      updateProgressVisibility();
    }

    function updateProgressVisibility() {
      $$('.progress-step').forEach((el) => el.classList.remove('is-hidden'));
    }

    function isMotiveUnlocked() {
      return state.entryDone;
    }

    function isTechnicalUnlocked() {
      return state.motive.size >= 2 && state.motiveConfirm !== null;
    }

    function isTechnicalComplete() {
      return Object.values(state.techDone).every(Boolean);
    }

    function isEconomicComplete() {
      return Object.values(state.econDone).every(Boolean);
    }

    function updateStageLocks() {
      const technicalUnlocked = isTechnicalUnlocked();
      const technicalComplete = isTechnicalComplete();
      const economicComplete = isEconomicComplete();

      $('techIntroLock')?.classList.toggle('is-locked', !technicalUnlocked);
      $('technicalStage')?.classList.toggle('is-locked', !technicalUnlocked);
      $('economicIntroLock')?.classList.toggle('is-locked', !technicalComplete);
      $('economicStage')?.classList.toggle('is-locked', !technicalComplete);
      $('step-6')?.classList.toggle('is-locked', !economicComplete);
      $('step-4')?.classList.toggle('is-locked', !economicComplete);
      $('step-5')?.classList.toggle('is-locked', !economicComplete);
    }

    function getPrimarySayTarget(step) {
      if (step === 1) return document.querySelector('.spoken-block.active');
      if (step === 2) return $('openingQuestion');
      if (step === 3) return $('technicalIntro');
      if (step === 4) return $('economicIntro');
      if (step === 5) return $('interestIntro');
      if (step === 6) return document.querySelector('#step-4 .accordion-body[style*="block"]') || document.querySelector('#step-4 .card');
      if (step === 7) return document.querySelector('#step-5 .term-line');
      return null;
    }

    function getQuestionTopOffset() {
      const progressShell = document.querySelector('.progress-shell');
      const progressHeight = document.body.classList.contains('guide-mode') && progressShell
        ? progressShell.getBoundingClientRect().height
        : 0;
      return progressHeight + 18;
    }

    function scrollSayIntoView(target) {
      if (!target) return;
      target.classList.add('say-focus');
      window.setTimeout(() => {
        target.classList.remove('say-focus');
      }, 420);
    }

    function scrollToStepStart(step) {
      const anchor = getPrimarySayTarget(step) || $(getSectionIdForStep(step));
      if (!anchor) return;
      const absoluteTop = window.pageYOffset + anchor.getBoundingClientRect().top;
      const offset = Math.max(absoluteTop - getQuestionTopOffset(), 0);
      window.scrollTo({ top: offset, behavior: 'smooth' });
    }

    function getSectionIdForStep(step) {
      if (step === 3) return 'step-2';
      if (step === 4) return 'step-2';
      if (step === 5) return 'step-6';
      if (step === 6) return 'step-4';
      if (step === 7) return 'step-5';
      return 'step-' + step;
    }

    function handleGuideScroll() {
      syncProgressForInlineSections();
    }

    function syncProgressForInlineSections() {
      if (state.mode !== 'guide') return;
      const step2Visible = $('step-2')?.classList.contains('visible');
      if (!step2Visible) return;
      const technical = $('technicalIntro');
      const economic = $('economicIntro');
      if (!technical || !economic) return;
      const technicalTop = technical.getBoundingClientRect().top;
      const economicTop = economic.getBoundingClientRect().top;
      let nextProgress = 2;
      if (economicTop <= 150) nextProgress = 4;
      else if (technicalTop <= 150) nextProgress = 3;
      if (state.currentStep !== nextProgress) {
        updateProgress(nextProgress);
      }
    }

    function showStep(step) {
      $$('.guide-screen .section').forEach((section) => section.classList.remove('visible'));
      const target = $(getSectionIdForStep(step));
      if (target) target.classList.add('visible');
      updateProgress(step);
      requestAnimationFrame(() => {
        scrollToStepStart(step);
        scrollSayIntoView(getPrimarySayTarget(step) || target);
      });
      requestAnimationFrame(syncProgressForInlineSections);
    }

    function syncKundenDaten() {
      state.kundenDaten.name = $('kunde-name').value;
      state.kundenDaten.telefon = $('kunde-telefon').value;
      state.kundenDaten.email = $('kunde-email').value;
      state.kundenDaten.ort = $('kunde-ort').value;
      state.kundenDaten.termin = $('kunde-termin').value;
      state.kundenDaten.berater = $('kunde-berater').value;
      state.kundenDaten.notizen = $('kunde-notizen').value;
    }

    function updateSummary() {
      syncKundenDaten();
      $('summary-name').textContent = valueOrDash(state.kundenDaten.name);
      $('summary-telefon').textContent = valueOrDash(state.kundenDaten.telefon);
      $('summary-email').textContent = valueOrDash(state.kundenDaten.email);
      $('summary-ort').textContent = valueOrDash(state.kundenDaten.ort);
      $('summary-termin').textContent = valueOrDash(state.kundenDaten.termin);
      $('summary-berater').textContent = valueOrDash(state.kundenDaten.berater);
      $('summary-notizen').textContent = valueOrDash(state.kundenDaten.notizen);
      $('summary-pfad').textContent = getPfadLabel();
      $('summary-thema').textContent = getThemaLabel();
    }

    function sortTechCards() {
      return;
    }

    function updateSelectPairSummary() {
      const heatSelect = $('heatSelectSummary');
      if (heatSelect) {
        const sourceMap = { gas: 'Gas', oil: 'Öl', other: 'Anderes' };
        heatSelect.textContent = sourceMap[state.heatSource] || '—';
      }
      const pv = $('pvSummary');
      if (pv) {
        const pvMap = { yes: 'Ja', no: 'Nein', planned: 'In Planung' };
        pv.textContent = pvMap[state.pvAnlage] || '—';
      }
    }

    function clearSelectPairIdle() {
      return;
    }

    function armSelectPairIdle() {
      return;
    }

    function updateTechSummaries() {
      updateSelectPairSummary();
      const building = $('buildingSummary');
      if (building) building.textContent = `${state.buildingYear} · ${state.buildingSubtype}`;
      const size = $('sizeSummary');
      if (size) size.textContent = `${formatNumberDE(state.houseSize)} qm · ${$('sizeCategoryValue')?.textContent || ''}`;
      const heat = $('heatSummary');
      if (heat) {
        const sourceMap = { gas: 'Gas', oil: 'Öl', other: 'Anderes' };
        let usage = 'nicht relevant';
        if (state.heatSource === 'gas') usage = `${formatNumberDE(state.heatUsage)} kWh / Jahr`;
        if (state.heatSource === 'oil') usage = `${formatNumberDE(state.heatUsage)} l / Jahr`;
        heat.textContent = `${sourceMap[state.heatSource] || '—'} · ${usage}`;
      }
      const power = $('powerSummary');
      if (power) power.textContent = `${formatNumberDE(state.powerUsage)} kWh / Jahr`;
    }

    function lockTechCardHeight(sectionKey) {
      const card = document.querySelector(`.tech-question-card[data-tech-question="${sectionKey}"]`);
      if (!card) return null;
      card.style.height = `${card.offsetHeight}px`;
      return card;
    }

    function unlockTechCardHeight(sectionKey) {
      const card = document.querySelector(`.tech-question-card[data-tech-question="${sectionKey}"]`);
      if (!card) return;
      card.style.height = '';
    }

    function clearTechIdle(sectionKey) {
      if (techIdleTimers[sectionKey]) {
        window.clearTimeout(techIdleTimers[sectionKey]);
        techIdleTimers[sectionKey] = null;
      }
      const card = document.querySelector(`.tech-question-card[data-tech-question="${sectionKey}"]`);
      if (card) {
        card.classList.remove('is-idle');
      }
      unlockTechCardHeight(sectionKey);
    }

    function armTechIdle(sectionKey) {
      if (!['building', 'size', 'heat', 'power', 'heatSelect', 'pv'].includes(sectionKey)) return;
      if (!techIdleEnabled[sectionKey]) return;
      clearTechIdle(sectionKey);
      techIdleTimers[sectionKey] = window.setTimeout(() => {
        updateTechSummaries();
        const card = lockTechCardHeight(sectionKey);
        if (card) {
          card.classList.add('is-idle');
        }
      }, 2000);
    }

    function registerTechActivity(sectionKey) {
      clearTechIdle(sectionKey);
      setTechnicalQuestion(sectionKey);
      armTechIdle(sectionKey);
    }

    function enableTechIdle(sectionKey) {
      techIdleEnabled[sectionKey] = true;
      registerTechActivity(sectionKey);
    }

    function animateSayBox(el) {
      if (!el) return;
      el.classList.remove('say-change');
      void el.offsetWidth;
      el.classList.add('say-change');
    }

    function updateSayBoxText(el, text, animate = true) {
      if (!el) return;
      if (el.textContent !== text) {
        el.textContent = text;
        if (animate) animateSayBox(el);
      }
    }

    function isTechnicalQuestionLocked() {
      return Date.now() < technicalQuestionLockUntil;
    }

    function lockTechnicalQuestion(ms = 5000) {
      technicalQuestionLockUntil = Date.now() + ms;
    }

    function getTechnicalQuestionText(key) {
      if (key === 'heat') {
        if (state.heatSource === 'oil') return '„Wie viel Öl verbrauchen Sie im Jahr?“';
        if (state.heatSource === 'gas') return '„Wie viel Gas verbrauchen Sie im Jahr?“';
        return '„Wie viel verbrauchen Sie im Jahr?“';
      }
      const map = {
        default: '„Herr/Frau [Name], ich habe noch ein, zwei technische Fragen.“',
        heatSelect: '„Herr / Frau [Name], für den Technischen Check habe ich noch ein zwei Fragen – wie heizen Sie bisher?“',
        pv: '„Nutzen Sie schon die Sonnen Energie ?“',
        building: '„Wann wurde Ihr Haus gebaut?“',
        size: '„Und wie viel Wohnfläche haben Sie?“',
        power: '„Wie viel Strom verbrauchen Sie im Jahr?“'
      };
      return map[key] || map.default;
    }

    function isTechnicalStepComplete(key) {
      if (key === 'heat') {
        if (state.heatSource === 'other') return true;
        return state.techDone.heat;
      }
      return Boolean(state.techDone[key]);
    }

    function getNextTechnicalQuestion() {
      const order = ['heatSelect', 'heat', 'building', 'size', 'pv', 'power'];
      return order.find((key) => !isTechnicalStepComplete(key)) || null;
    }

    function advanceTechnicalQuestion(force = true) {
      const next = getNextTechnicalQuestion();
      if (next) {
        setTechnicalQuestion(next, true, force);
      }
    }

    function setTechnicalQuestion(key = 'building', animate = true, force = false) {
      const intro = $('technicalIntro');
      if (!intro) return;
      updateSayBoxText(intro, getTechnicalQuestionText(key), animate);
      $$('.tech-question-card').forEach((card) => card.classList.remove('is-active'));
      if (key !== 'default') {
        document.querySelector(`.tech-question-card[data-tech-question="${key}"]`)?.classList.add('is-active');
      }
    }

    function applyGuide() {
      const cfg = currentGuide();
      $('step1Goal').textContent = cfg.step1Goal;
      updateSayBoxText($('openingQuestion'), cfg.openingQuestion);
      $('openingQuestion').classList.remove('hidden');
      $('step3Sub').textContent = cfg.step3Sub;
      updateSayBoxText($('interestIntro'), cfg.interestIntro);
      showSpoken();
      resetTechnicalCheck();
      setTechnicalQuestion('building', false);
      updateMotiveFollowup();
      showObjectionGroup(cfg.defaultObjection);
    }

    function resetSpokenProgress() {
      $$('.spoken-block').forEach((block) => {
        const items = block.querySelectorAll('.spoken-item');
        items.forEach((item, index) => {
          item.classList.toggle('hidden', index > 0);
        });
        const firstResponse = block.querySelector('.response-actions');
        if (firstResponse) firstResponse.classList.remove('hidden');
        const secondResponse = block.querySelector('.second-response-actions');
        if (secondResponse) secondResponse.classList.add('hidden');
      });
    }

    function handleFirstResponse(btn) {
      const block = btn.closest('.spoken-block');
      if (!block) return;
      const response = btn.dataset.response;
      if (response === 'no') {
        state.entryDone = false;
        setMode('prep');
        updateProgress(0);
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }

      const actions = btn.closest('.response-actions');
      if (actions) actions.classList.add('hidden');

      const items = Array.from(block.querySelectorAll('.spoken-item'));
      const currentIndex = items.findIndex((item) => !item.classList.contains('hidden'));

      if (currentIndex >= 0) {
        items[currentIndex].classList.add('hidden');
      }

      const nextItem = currentIndex >= 0 ? items[currentIndex + 1] : null;
      if (nextItem) {
        nextItem.classList.remove('hidden');
        const secondResponse = block.querySelector('.second-response-actions');
        if (secondResponse) secondResponse.classList.remove('hidden');
        requestAnimationFrame(() => scrollSayIntoView(nextItem));
      } else {
        state.entryDone = true;
        updateStageLocks();
        showStep(2);
      }
    }

    function handleSecondResponse(btn) {
      const response = btn.dataset.response;
      if (response === 'no') {
        state.entryDone = false;
        setMode('prep');
        updateProgress(0);
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      state.entryDone = true;
      updateStageLocks();
      showStep(2);
    }

    function showSpoken() {
      $$('.spoken-block').forEach((el) => el.classList.remove('active'));
      if (state.pfad === 'empfehlung') $('spoken-empfehlung').classList.add('active');
      else if (state.thema) $('spoken-' + state.thema).classList.add('active');
      resetSpokenProgress();
    }

    function scrollPrepTarget(target) {
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const absoluteTop = window.pageYOffset + rect.top;
      const offset = Math.max(absoluteTop - 120, 0);
      window.scrollTo({ top: offset, behavior: 'smooth' });
    }

    function setPfad(pfad) {
      state.pfad = pfad;
      state.thema = null;
      $('pfad-lead').classList.remove('active');
      $('pfad-empfehlung').classList.remove('active');
      $('pfad-' + pfad).classList.add('active');
      $$('.topic-btn').forEach((btn) => btn.classList.remove('active'));
      if (pfad === 'lead') {
        $('themeCard').style.display = 'block';
        requestAnimationFrame(() => scrollPrepTarget($('themeCard')));
      } else {
        $('themeCard').style.display = 'none';
        updateSummary();
        startGuide();
        return;
      }
      updateSummary();
      updateStageLocks();
    }

    function setTopic(topic) {
      state.thema = topic;
      $$('.topic-btn').forEach((btn) => btn.classList.remove('active'));
      $('topic-' + topic).classList.add('active');
      updateSummary();
      startGuide();
    }

    function startGuide() {
      updateSummary();
      if (!state.pfad) {
        alert('Bitte zuerst die Kontaktart auswählen.');
        return;
      }
      if (state.pfad === 'lead' && !state.thema) {
        alert('Bitte zusätzlich das Thema auswählen.');
        return;
      }
      applyGuide();
      setMode('guide');
      showStep(1);
    }

    function toggleRules() {
      const body = $('rulesBody');
      const open = body.style.display === 'block';
      body.style.display = open ? 'none' : 'block';
      $('rulesArrow').style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
    }

    const motiveQuestionLabels = {
      gaskosten: 'hohe Energiekosten / Gas für Sie wichtig sind',
      unabhaengig: 'Unabhängigkeit für Sie wichtig ist',
      zukunft: 'das Thema Zukunft / Gesetzeslage für Sie wichtig ist',
      'heizung-alt': 'der Zustand Ihrer aktuellen Heizung für Sie wichtig ist',
      pv: 'die Kombination mit einer PV-Anlage für Sie wichtig ist',
      machbarkeit: 'die Machbarkeit bei Ihrem Haus für Sie wichtig ist',
      foerderung: 'das Thema Förderung für Sie wichtig ist',
      neubau: 'Ihre Neubau- / Sanierungssituation für Sie wichtig ist'
    };

    const motiveCloseLabels = {
      gaskosten: 'Ihre Energiekosten senken',
      unabhaengig: 'mehr Unabhängigkeit schaffen',
      zukunft: 'für die Zukunft sauber aufgestellt sein',
      'heizung-alt': 'die alte Heizung sinnvoll ersetzen',
      pv: 'die PV sinnvoll mit der Wärmepumpe kombinieren',
      machbarkeit: 'die Machbarkeit bei Ihrem Haus sauber klären',
      foerderung: 'die passende Förderung für Sie nutzen',
      neubau: 'Ihre Neubau- / Sanierungssituation optimal nutzen'
    };

    function updateMotiveCloseBox() {
      const wrap = $('motiveCloseWrap');
      const question = $('motiveCloseQuestion');
      if (!wrap || !question) return;

      if (state.motive.size >= 2) {
        const labels = Array.from(state.motive).map((key) => motiveCloseLabels[key]).filter(Boolean);
        const joined = labels.length === 2
          ? `${labels[0]} und ${labels[1]}`
          : `${labels.slice(0, -1).join(', ')} und ${labels[labels.length - 1]}`;
        updateSayBoxText(question, `„Wenn Sie ${joined}, dann steht einer Umsetzung eigentlich nichts im Weg, oder?“`);
        wrap.style.display = 'grid';
        $('motiveCloseYes')?.classList.toggle('selected', state.motiveConfirm === 'yes');
        $('motiveCloseNo')?.classList.toggle('selected', state.motiveConfirm === 'no');
      } else {
        wrap.style.display = 'none';
        state.motiveConfirm = null;
      }
    }

    function answerMotiveClose(answer) {
      state.motiveConfirm = answer;
      updateMotiveCloseBox();
      updateStageLocks();
      if (answer === 'yes') {
        lockTechnicalQuestion(5000);
        setTechnicalQuestion('heatSelect', true, true);
        showStep(3);
      }
    }

    function updateMotiveFollowup() {
      const opening = $('openingQuestion');
      const followup = $('motiveFollowupQuote');
      if (!opening) return;

      if (followup) {
        followup.classList.remove('visible');
      }

      opening.classList.remove('hidden');
      opening.classList.toggle('warn-state', state.motive.size > 0);

      if (state.motive.size > 0) {
        const activeKey = state.lastMotive && state.motive.has(state.lastMotive)
          ? state.lastMotive
          : Array.from(state.motive)[0];
        const motiveText = motiveQuestionLabels[activeKey] || 'dieser Punkt für Sie wichtig ist';
        updateSayBoxText(opening, `„Ich verstehe, dass ${motiveText}. Gibt es denn weitere Gründe, die für die Wärmepumpe bei Ihnen sprechen?“`);
      } else {
        updateSayBoxText(opening, currentGuide().openingQuestion);
      }
      updateMotiveCloseBox();
      updateStageLocks();
    }

    function toggleMotive(key, btn) {
      if (state.motive.has(key)) {
        state.motive.delete(key);
        btn.classList.remove('active');
        if (state.lastMotive === key) {
          state.lastMotive = state.motive.size ? Array.from(state.motive)[state.motive.size - 1] : null;
        }
      } else {
        state.motive.add(key);
        state.lastMotive = key;
        btn.classList.add('active');
      }
      if (state.motive.size < 2) state.motiveConfirm = null;
      updateProgressVisibility();
      updateMotiveFollowup();
      updateClosing();
      updateInterest();
      updateSummary();
      updateStageLocks();
    }

