      else if (size > 220) label = '🏢 Groß';
      const valueEl = $('sizeCategoryValue');
      if (valueEl) valueEl.textContent = label;
    }

    function getAutoGasUsage() {
      const raw = state.houseSize * state.buildingKwhPerSqm;
      const rounded = Math.round(raw / 500) * 500;
      return Math.max(0, Math.min(45000, rounded));
    }

    function syncAutoHeatUsage() {
      if (!state.heatUsageManual && state.heatSource === 'gas') {
        state.heatUsage = getAutoGasUsage();
      }
      updateHeatUsageUI();
    }

