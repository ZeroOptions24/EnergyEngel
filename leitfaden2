    function updateInterest() {
      const map = {
        gaskosten: state.tags.has('hohe-gaskosten') || state.motive.has('gaskosten'),
        pv: state.motive.has('pv') || state.tags.has('pv-vorhanden'),
        unabhaengig: state.motive.has('unabhaengig'),
        foerderung: true,
        geg: state.tags.has('geg') || state.motive.has('zukunft'),
        neubau: state.tags.has('neubau') || state.motive.has('neubau')
      };
      let shown = 0;
      Object.entries(map).forEach(([key, visible]) => {
        const el = $('interest-' + key);
        if (!el) return;
        el.classList.toggle('visible', visible);
        if (visible) shown += 1;
      });
      $('interestHint').textContent = shown > 0
        ? 'Es werden jetzt nur die Argumente angezeigt, die zur Situation des Kunden passen.'
        : '← Erst Kundensituation in der Qualifizierung anklicken – dann erscheinen hier die passenden Argumente.';
    }

    function updateClosing() {
      const labels = {
        gaskosten: 'dass Sie Ihre hohen Energiekosten in den Griff bekommen wollen',
        unabhaengig: 'dass Sie unabhängiger von Energiepreisen werden möchten',
        zukunft: 'dass Sie beim Thema Zukunft und Gesetzeslage Klarheit wollen',
        'heizung-alt': 'dass Ihre Heizung alt ist oder das Thema ohnehin ansteht',
        pv: 'dass Sie Ihre bestehende PV sinnvoll ergänzen möchten',
        machbarkeit: 'dass Sie zuerst wissen möchten, ob die Wärmepumpe bei Ihrem Haus technisch sinnvoll machbar ist',
        foerderung: 'dass die mögliche Förderung für Ihre Entscheidung wichtig ist',
        neubau: 'dass Sie ohnehin im Neubau oder in der Sanierung sind'
      };
      const motives = Array.from(state.motive).map((m) => labels[m]).filter(Boolean);
      if (!motives.length) {
        $('closingText').textContent = '„Sie haben ja selbst gesagt, dass [Grund 1], [Grund 2] und [Grund 3] für Sie wichtig sind. Und genau deshalb macht es Sinn, dass wir uns das einmal sauber bei Ihnen anschauen.“';
        return;
      }
      const joined = motives.length === 1 ? motives[0] : motives.length === 2 ? motives[0] + ' und ' + motives[1] : motives.slice(0, -1).join(', ') + ' und ' + motives[motives.length - 1];
      $('closingText').textContent = `„Sie haben ja selbst gesagt, ${joined}. Und genau deshalb macht es Sinn, dass wir uns das einmal sauber bei Ihnen anschauen.“`;
    }

