      { min: 1919, max: 1948, category: 'altbau', label: 'Vorkrieg', kwh: 280 },
      { min: 1949, max: 1957, category: 'altbau', label: 'Nachkrieg', kwh: 260 },
      { min: 1958, max: 1968, category: 'altbau', label: 'Wirtschaftswunder', kwh: 230 },
      { min: 1969, max: 1978, category: 'altbau', label: 'Vor 1. WSchVO', kwh: 200 },
      { min: 1979, max: 1983, category: 'altbau', label: 'Nach 1. WSchVO', kwh: 160 },
      { min: 1984, max: 1994, category: 'altbau', label: 'Nach 2. WSchVO', kwh: 130 },
      { min: 1995, max: 2001, category: 'altbau', label: 'Nach 3. WSchVO', kwh: 100 },
