    function goToProgressStep(step) {
      const numeric = Number(step);
      if (numeric === 0) {
        setMode('prep');
        updateProgress(0);
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      if (state.mode !== 'guide') return;
      showStep(numeric);
    }

    function bind() {
      $('pfad-lead').addEventListener('click', () => setPfad('lead'));
      $('pfad-empfehlung').addEventListener('click', () => setPfad('empfehlung'));
      $$('.topic-btn').forEach((btn) => btn.addEventListener('click', () => setTopic(btn.dataset.topic)));

      $('backBtn').addEventListener('click', () => {
        if (state.currentStep === 1) {
          const block = document.querySelector('.spoken-block.active');
          if (block) {
            const items = Array.from(block.querySelectorAll('.spoken-item'));
            const hasFollowupVisible = items.some((item, index) => index > 0 && !item.classList.contains('hidden'));
            if (hasFollowupVisible) {
              items.forEach((item, index) => item.classList.toggle('hidden', index > 0));
              const firstActions = block.querySelector('.response-actions');
              if (firstActions) firstActions.classList.remove('hidden');
              const secondActions = block.querySelector('.second-response-actions');
              if (secondActions) secondActions.classList.add('hidden');
              requestAnimationFrame(() => scrollSayIntoView(block));
              return;
            }
          }
          setMode('prep');
          updateProgress(0);
          window.scrollTo({ top: 0, behavior: 'smooth' });
          return;
        }

        if (state.currentStep === 2 && (state.motive.size > 0 || state.heatSource || state.pvAnlage || state.buildingYear !== 1995 || state.houseSize !== 140)) {
          state.motive.clear();
          $$('.motive-btn').forEach((btn) => btn.classList.remove('active'));
          resetTechnicalCheck();
          updateMotiveFollowup();
          updateClosing();
          updateInterest();
          updateSummary();
          requestAnimationFrame(() => scrollSayIntoView($('openingQuestion')));
          return;
        }

        if (state.currentStep > 1) {
          showStep(state.currentStep - 1);
        } else {
          setMode('prep');
          updateProgress(0);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      $$('.progress-step').forEach((btn) => btn.addEventListener('click', () => goToProgressStep(btn.dataset.progress)));
      $('rulesCard').addEventListener('click', toggleRules);
      $$('[data-next]').forEach((btn) => btn.addEventListener('click', () => showStep(Number(btn.dataset.next))));
      $$('.first-response-btn').forEach((btn) => btn.addEventListener('click', () => handleFirstResponse(btn)));
      $$('.second-response-btn').forEach((btn) => btn.addEventListener('click', () => handleSecondResponse(btn)));
      $$('.motive-btn').forEach((btn) => btn.addEventListener('click', () => toggleMotive(btn.dataset.motive, btn)));
      $$('.tech-question-card').forEach((card) => {
        card.addEventListener('mouseenter', () => {
          if (card.classList.contains('is-idle')) return;
          if (isTechnicalQuestionLocked()) return;
          setTechnicalQuestion(card.dataset.techQuestion);
        });
        card.addEventListener('click', (event) => {
          const interactive = event.target.closest('button, input, textarea, select, label');
          if (interactive) return;
          const key = card.dataset.techQuestion;
          clearTechIdle(key);
          if (!isTechnicalQuestionLocked()) {
            setTechnicalQuestion(key);
          }
        });
      });
      $('technicalCheckPanel')?.addEventListener('mouseleave', () => {
        if (isTechnicalQuestionLocked()) return;
        setTechnicalQuestion('default');
      });
      $$('.building-type-btn').forEach((btn) => btn.addEventListener('click', () => selectBuildingType(btn.dataset.building, btn)));
      $$('.size-btn').forEach((btn) => btn.addEventListener('click', () => selectSizeBucket(btn.dataset.size, btn)));
      $$('.heat-source-btn').forEach((btn) => btn.addEventListener('click', () => selectHeatSource(btn.dataset.source, btn)));
      $$('.pv-btn').forEach((btn) => btn.addEventListener('click', () => selectPv(btn.dataset.pv, btn)));
      $('buildingYearSlider')?.addEventListener('input', updateBuildingYear);
      $('sizeSlider')?.addEventListener('input', updateSizeSlider);
      $('heatUsageSlider')?.addEventListener('input', updateHeatUsageSlider);
      $('powerUsageSlider')?.addEventListener('input', () => {
        state.techDone.power = true;
        enableTechIdle('power');
        setTechnicalQuestion('power');
        updatePowerUsage();
      });
      $('econBuildingYearSlider')?.addEventListener('input', () => {
        state.econDone.building = true;
        setText('econBuildingYearValue', $('econBuildingYearSlider').value);
        updateStageLocks();
      });
      $('econSizeSlider')?.addEventListener('input', () => {
        state.econDone.size = true;
        setText('econSizeValue', `${formatNumberDE(Number($('econSizeSlider').value))} qm`);
        updateStageLocks();
      });
      $('econHeatUsageSlider')?.addEventListener('input', () => {
        state.econDone.heat = true;
        updateEconomicHeatUsageUI();
        updateStageLocks();
      });
      $('econPowerUsageSlider')?.addEventListener('input', () => {
        state.econDone.power = true;
        setText('econPowerUsageValue', `${formatNumberDE(Number($('econPowerUsageSlider').value))} kWh / Jahr`);
        updateStageLocks();
      });
      $$('.tag-btn').forEach((btn) => btn.addEventListener('click', () => toggleTag(btn.dataset.tag, btn)));
      $$('.info-btn').forEach((btn) => btn.addEventListener('click', () => showInfo(btn.dataset.info, btn)));
      $$('.objection-tab').forEach((btn) => btn.addEventListener('click', () => showObjectionGroup(btn.dataset.group)));
      $$('[data-acc]').forEach((btn) => btn.addEventListener('click', () => toggleAccordion(btn.dataset.acc)));
      $$('.term-step').forEach((el) => el.addEventListener('click', () => toggleTermStep(Number(el.dataset.term), el)));
      ['kunde-name','kunde-telefon','kunde-email','kunde-ort','kunde-termin','kunde-berater','kunde-notizen'].forEach((id) => $(id).addEventListener('input', updateSummary));
      $('refreshBtn').addEventListener('click', updateSummary);
      $('motiveCloseYes')?.addEventListener('click', () => answerMotiveClose('yes'));
      $('motiveCloseNo')?.addEventListener('click', () => answerMotiveClose('no'));
      $('exportBtn').addEventListener('click', exportPdf);
    }

    bind();
    window.addEventListener('scroll', handleGuideScroll, { passive: true });
    updateProgress(0);
    updateProgressVisibility();
    updateStageLocks();
    updateSummary();
  </script>
</body>
</html>
